{
  "name": "@liberte/svelte-icons",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liberte-top/design.svelte.git",
    "directory": "packages/icons"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "svelte-kit sync && svelte-package",
    "format": "prettier --plugin prettier-plugin-svelte --check package.json svelte.config.js tsconfig.json \"src/**/*.{svelte,ts}\"",
    "format:write": "prettier --plugin prettier-plugin-svelte --write package.json svelte.config.js tsconfig.json \"src/**/*.{svelte,ts}\"",
    "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "5.55.5"
  },
  "dependencies": {
    "lucide-svelte": "1.0.1"
  },
  "devDependencies": {
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/package": "2.5.7",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "25.6.2",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.5",
    "svelte-check": "4.4.8",
    "typescript": "6.0.3",
    "vite": "8.0.11"
  },
  "publishConfig": {
    "registry": "https://packages.liberte.top/"
  }
}
