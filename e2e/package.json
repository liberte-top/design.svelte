{
  "name": "@liberte/design.svelte-e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --check package.json playwright.config.ts \"tests/**/*.ts\"",
    "format:write": "prettier --write package.json playwright.config.ts \"tests/**/*.ts\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.2",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  }
}
